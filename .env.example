# AI Gateway (OpenRouter / OpenAI-compatible)
GATEWAY_TOKEN=your_openrouter_api_key_here
GATEWAY_BASE_URL=https://openrouter.ai/api/v1
GATEWAY_MODEL=google/gemini-2.5-flash

# CORS: origin браузера (без path), совпадает со схемой+хостом+портом фронта
FRONTEND_URL=http://localhost:3000

# Публичный origin фронта (без path). Используется для ссылок в ответах API
APP_PUBLIC_URL=http://localhost:3000

# Префикс URL приложения, со слэшем в конце (как у Vite/CRA base). Корень: /
BASE_PATH=/

# Docker: порт nginx (compose)
# PORT=3000
